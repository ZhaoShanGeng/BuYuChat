{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BuYu",
  "version": "0.1.2",
  "identifier": "com.buyu.app",
  "build": {
    "beforeDevCommand": "node scripts/ensure-dev-server.mjs",
    "beforeBuildCommand": "node scripts/prepare-tauri-build.mjs",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "BuYu",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
