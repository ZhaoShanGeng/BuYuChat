{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "步语",
  "version": "0.1.0",
  "identifier": "com.buyu.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "步语",
        "width": 1280,
        "height": 860,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
